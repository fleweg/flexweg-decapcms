# Application Environment
APP_ENV=development
NODE_ENV=development

# Project Configuration
PROJECT_NAME=flexweg-decapcms
APP_FQDN=flexweg.local

# Docker Configuration
DOCKER_IMAGE=flexweg
DOCKER_IMAGE_TAG=latest
NODE_VERSION=20

# Ports (for local development without Traefik)
ADMIN_PORT=3333
SITE_PORT=8080

# Flexweg API Configuration (for deployment)
FLEXWEG_API_KEY=your_api_key_here
FLEXWEG_BASE_URL=https://api.flexweg.com
