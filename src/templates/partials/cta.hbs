<div class="alert alert-primary mb-4" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border: none; color: white; padding: 2rem; border-radius: 12px;">
  <h3 class="mt-0" style="color: white; margin-bottom: 1rem;">{{title}}</h3>
  <p style="margin-bottom: 1.5rem;">{{text}}</p>
  <a href="{{buttonUrl}}" class="btn btn-light">{{buttonText}}</a>
</div>
