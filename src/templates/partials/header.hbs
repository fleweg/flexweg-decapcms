<!-- Header -->
<header class="site-header">
  <nav class="navbar navbar-light">
    <div class="container">
      <a class="navbar-brand" href="{{navigation.header.logo.url}}">
        {{navigation.header.logo.text}}
      </a>

      <!-- Burger Menu Button -->
      <button class="navbar-toggler border-0" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvasNavbar" aria-controls="offcanvasNavbar">
        <span class="navbar-toggler-icon"></span>
      </button>
    </div>
  </nav>
</header>

<!-- Offcanvas Menu -->
<div class="offcanvas offcanvas-end" tabindex="-1" id="offcanvasNavbar" aria-labelledby="offcanvasNavbarLabel">
  <div class="offcanvas-header">
    <h5 class="offcanvas-title" id="offcanvasNavbarLabel">{{navigation.header.logo.text}}</h5>
    <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
  </div>
  <div class="offcanvas-body">
    <ul class="navbar-nav justify-content-end flex-grow-1 pe-3">
      {{#each navigation.header.links}}
      <li class="nav-item">
        <a class="nav-link {{isActive url ../currentUrl}}" href="{{url}}">{{text}}</a>
      </li>
      {{/each}}
      <li class="nav-item mt-3">
        <hr class="dropdown-divider">
      </li>
      <li class="nav-item">
        <p class="nav-link fw-bold mb-2">Theme</p>
        <div class="d-flex flex-column gap-2">
          <button type="button" class="btn btn-outline-secondary d-flex align-items-center justify-content-start" data-bs-theme-value="light" aria-pressed="false">
            <svg class="bi me-2" width="1em" height="1em"><use href="#sun-fill"></use></svg>
            Light
            <svg class="bi ms-auto d-none" width="1em" height="1em"><use href="#check2"></use></svg>
          </button>
          <button type="button" class="btn btn-outline-secondary d-flex align-items-center justify-content-start" data-bs-theme-value="dark" aria-pressed="false">
            <svg class="bi me-2" width="1em" height="1em"><use href="#moon-stars-fill"></use></svg>
            Dark
            <svg class="bi ms-auto d-none" width="1em" height="1em"><use href="#check2"></use></svg>
          </button>
          <button type="button" class="btn btn-outline-secondary d-flex align-items-center justify-content-start active" data-bs-theme-value="auto" aria-pressed="true">
            <svg class="bi me-2" width="1em" height="1em"><use href="#circle-half"></use></svg>
            Auto
            <svg class="bi ms-auto d-none" width="1em" height="1em"><use href="#check2"></use></svg>
          </button>
        </div>
      </li>
    </ul>
  </div>
</div>
