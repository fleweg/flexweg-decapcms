<!DOCTYPE html>
<html lang="{{site.language}}" data-bs-theme="light">
<head>
{{> meta-common}}
  <meta name="description" content="{{#if page.description}}{{page.description}}{{else}}{{site.description}}{{/if}}">
  <meta name="author" content="{{site.author}}">

  <!-- Open Graph -->
  <meta property="og:title" content="{{pageTitle}}">
  <meta property="og:description" content="{{#if page.description}}{{page.description}}{{else}}{{site.description}}{{/if}}">
  <meta property="og:url" content="{{site.url}}{{currentUrl}}">
  <meta property="og:type" content="website">
  <meta property="og:image" content="{{site.url}}{{site.defaultImage}}">

  <title>{{pageTitle}}</title>
</head>
<body>
  {{> theme-icons}}

  {{> header}}

  <!-- Main Content -->
  <main class="site-main">
    <!-- Page Header -->
    <section class="page-header">
      <div class="container">
        <div class="row">
          <div class="col-lg-8 mx-auto">
            <h1 class="page-title">{{page.title}}</h1>
            {{#if page.description}}
            <p class="page-description">{{page.description}}</p>
            {{/if}}
          </div>
        </div>
      </div>
    </section>

    <!-- Page Content -->
    <section class="page-content">
      <div class="container">
        <div class="row">
          <div class="col-lg-8 mx-auto">
            <div class="prose">
              {{{page.content}}}
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  {{> footer}}

  {{> scripts}}
</body>
</html>
