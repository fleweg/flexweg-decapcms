{
  "name": "flexweg-decapcms",
  "version": "1.0.0",
  "description": "Static site generator with Bootstrap and dynamic article feed",
  "main": "build.js",
  "scripts": {
    "build": "node build.js",
    "dev": "node dev-server.js",
    "deploy": "npm run build && node sync-flexweg.js",
    "new-article": "node scripts/new-article.js",
    "clean": "rm -rf public/*",
    "images:process": "node scripts/process-images.js",
    "images:watch": "node scripts/watch-images.js"
  },
  "keywords": [
    "static-site",
    "generator",
    "bootstrap"
  ],
  "author": "Frederic Leaux",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "fs-extra": "^11.2.0",
    "gray-matter": "^4.0.3",
    "handlebars": "^4.7.8",
    "markdown-it": "^14.0.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "chokidar": "^3.5.3",
    "cors": "^2.8.5",
    "decap-server": "^3.0.0",
    "express": "^4.18.2",
    "live-server": "^1.2.2"
  }
}
